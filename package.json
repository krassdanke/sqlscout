{
  "name": "sqlscout",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-dialect SQL command explorer and visual playground.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build --workspaces --if-present && tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "test": "npm run test --workspaces --if-present && npm run test:e2e",
    "test:e2e": "vitest run",
    "release:packages": "npm publish --workspaces --access public --dry-run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@sqlscout/core": "*",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
